{
  "name": "@tsonic/target-python",
  "version": "0.0.1",
  "description": "Python target pack for Tsonic",
  "type": "module",
  "tsonic": {
    "kind": "plugin",
    "contractVersion": 1,
    "entry": "."
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "npm run build && node --test test/*.test.mjs test/architecture/*.test.mjs"
  },
  "peerDependencies": {
    "@tsonic/source-core": "0.0.1",
    "@tsonic/target-api": "0.0.1",
    "@tsonic/tsts": "0.0.0",
    "@tsonic/target-gpu": "0.0.1"
  },
  "devDependencies": {
    "@tsonic/source-core": "file:../tsonic/packages/source-core",
    "@tsonic/target-api": "file:../tsonic/packages/target-api",
    "@tsonic/tsts": "file:../tsonic/packages/tsts",
    "@tsonic/target-gpu": "file:../tsonic-gpu",
    "@tsonic/host": "file:../tsonic/packages/host"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "peerDependenciesMeta": {
    "@tsonic/target-gpu": {
      "optional": true
    }
  }
}
